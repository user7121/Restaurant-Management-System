# Admin Frontend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# Base URL of the backend API (used by the admin dashboard's Vite proxy in dev)
# In production set this to the actual API URL.
VITE_API_URL=http://localhost:5000

# Public URL of the customer ordering app — used to generate QR codes
# In development: http://localhost:5174
# In production: set to the deployed customer app URL (e.g. https://order.yourdomain.com)
VITE_CUSTOMER_APP_URL=http://localhost:5174
